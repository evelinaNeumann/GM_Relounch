  }

  .cloud-card__points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    color: #1d2738;
    font-size: 0.92rem;
  }

  .cloud-card__points li {
    display: flex;
    gap: 0.35rem;
    align-items: flex-start;
  }

  .cloud-card__points li::before {
    content: '•';
    color: rgb(0, 150, 153);
    margin-right: 0.35rem;
  }

  .cloud-card__cta {
    margin-top: auto;
    font-weight: 600;
    color: rgb(0, 150, 153);
    text-decoration: none;
  }

  .cloud-hero--modern .cloud-card--hero .cloud-card__cta {
    color: #ffffff;
  }

  .cloud-section--split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1rem, 3vw, 3rem);
    align-items: flex-start;
  }

  .cloud-panels {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .cloud-panel {
    background: #ffffff;
    border: 1px solid rgba(15, 39, 66, 0.12);
    border-radius: 1rem;
    padding: 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    box-shadow: 0 16px 45px rgba(15, 39, 66, 0.07);
  }

  .cloud-panel__list {
    margin: 0;
    padding-left: 1rem;
    color: var(--color-muted);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .cloud-panel__cta {
    margin-top: auto;
    color: rgb(0, 150, 153);
    font-weight: 600;
    text-decoration: none;
  }

  .page.modern .cloud-card,
  .page.modern .cloud-panel {
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(15, 39, 66, 0.08);
  }

  .page.modern .cloud-panel__cta {
    color: #ffffff;
  }

  .page.modern .cloud-card {
    box-shadow: none;
  }

  .page.modern .cloud-panel {
    background: rgba(15, 39, 66, 0.25);
    color: #ffffff;
  }

  .page.modern .cloud-panel__list {
    color: rgba(255, 255, 255, 0.85);
  }

  @media (max-width: 1024px) {
    .cloud-hero {
      grid-template-columns: minmax(0, 1fr);
    }

    .cloud-section--split {
      grid-template-columns: minmax(0, 1fr);
    }

    .cloud-header__actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 600px) {
    .cloud-card,
    .cloud-panel {
      padding: 1rem;
    }

    .cloud-card__title {
      font-size: 1.05rem;
    }

    .cloud-header__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
}

