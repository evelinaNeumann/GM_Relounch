.page-layout {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  column-gap: clamp(2rem, 6vw, 100px);
  row-gap: 1.5rem;
  align-items: flex-start;
  max-width: 1680px;
  margin: 0 auto;
  padding: 1rem 1.25rem 2.5rem;
  position: relative;
  z-index: 0;
}

.page.tech .page-layout {
  grid-template-columns: minmax(0, 1fr);
  column-gap: 0;
  padding: 0 0 2.5rem;
}

.page-layout--single {
  grid-template-columns: minmax(0, 1fr);
  column-gap: 0;
}

.page.modern .page-layout {
  grid-template-columns: minmax(0, 1fr);
  column-gap: 0;
}

.managed-services-page .page-layout {
  padding-left: 0;
  padding-right: 0;
}

.page-stack {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  width: 100%;
}

.section-shell {
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
}

.section-shell--flush {
  max-width: 1680px;
  margin: 0 auto;
  width: 100%;
  grid-column: 1 / -1;
}
.page.tech #solutions.section--flush,
.page.tech #services.section--flush,
.page.tech #news.section--flush {
  padding-right: var(--section-flush-inline);
}

.section-shell--hero {
  margin: 0;
  margin-top: 0.5rem;
  max-width: none;
  width: 100%;
  padding: 0;
  grid-column: 1 / -1;
}

.page.tech .section-shell--hero {
  margin-top: 0;
  width: 100%;
  max-width: none;
  margin-left: 0;
  margin-right: 0;
  /* Tech UI: push hero content down by 120px, keep the 20px separator */
  padding-top: calc(20px + 120px);
  position: relative;
}

/* Tech UI: translucent 20px separator between header and hero */
.page.tech .section-shell--hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 20px;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(10px);
  pointer-events: none;
}

@media (max-width: 768px) {
  .section-shell--hero {
    margin-top: calc(0.5rem + 40px);
  }

  .page.tech .section-shell--hero {
    padding-top: calc(20px + 120px + 40px);
  }
}

.section-shell + .section-shell {
  margin-top: 1rem;
}

.cert-rail {
  position: -webkit-sticky;
  position: sticky;
  top: calc(var(--header-height, 78px) + 20px);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  gap: var(--cert-rail-gap, 12px);
  height: var(--solutions-height, clamp(640px, 75vh, 1100px));
  pointer-events: none;
  width: 188px;
  z-index: 1;
  box-sizing: border-box;
  margin-top: var(--solutions-offset, 0px);
  will-change: opacity, transform;
}

.cert-rail__link {
  width: 100%;
  display: block;
  pointer-events: auto;
  text-decoration: none;
}

.cert-rail__link:focus-visible .cert-rail__image {
  outline: 2px solid var(--color-accent);
  outline-offset: 4px;
}

.cert-rail--left {
  align-items: flex-start;
}

.cert-rail--right {
  align-items: flex-end;
}

.cert-rail-row {
  position: -webkit-sticky;
  position: sticky;
  top: calc(var(--header-height, 78px) + var(--header-safe-offset, 0px));
  box-sizing: border-box;
  display: flex;
  flex-wrap: nowrap;
  gap: clamp(0.5rem, 1.2vw, 1rem);
  justify-content: center;
  align-items: center;
  pointer-events: auto;
  grid-column: 1 / -1;
  width: calc(100vw - 2px);
  margin-left: calc(50% - 50vw + 1px);
  margin-right: calc(50% - 50vw + 1px);
  padding: 0.65rem clamp(1rem, 3vw, 2.5rem);
  border-radius: 0;
  background: rgb(29, 47, 61);
  border: 1px solid rgba(148, 163, 184, 0.35);
  box-shadow: 0 20px 60px rgba(15, 23, 42, 0.2);
  z-index: 25;
  overflow: visible;
  will-change: opacity, transform;
  backface-visibility: hidden;
  transform: translate3d(0, 0, 0);
}

.cert-rail-row__inner {
  width: 100%;
  display: flex;
  flex-wrap: nowrap;
  gap: clamp(0.5rem, 1.2vw, 1rem);
  justify-content: center;
  align-items: center;
  overflow: visible;
}

.page.tech .cert-rail-row--sticky {
  position: fixed;
  top: calc(var(--header-height, 78px) + var(--header-safe-offset, 0px) + 10px);
  left: 0;
  right: 0;
  width: 100%;
  max-width: 1680px;
  margin-left: auto;
  margin-right: auto;
  transform: none;
  z-index: 50;
  background: rgb(53, 44, 56);
  border-color: rgba(255, 255, 255, 0.15);
  box-shadow: 0 25px 60px rgba(7, 6, 12, 0.45);
}

.page.tech .cert-rail-row--below-hero {
  position: relative;
  top: auto;
  left: auto;
  width: min(100%, 1680px);
  max-width: 1680px;
  margin: 10px auto 0;
  transform: none;
  z-index: 70;
  border-radius: 0;
  background: rgb(53, 44, 56);
  border-color: rgba(255, 255, 255, 0.15);
  box-shadow: 0 25px 60px rgba(7, 6, 12, 0.45);
}

/* When the tech cert row is active (collapsed rails), reserve space so it never overlaps content. */
.page.tech.has-cert-rail-row .page-stack {
  padding-top: calc(10px + var(--cert-rail-row-height, 76px));
}

.page.tech .cert-rail-row {
  min-height: var(--cert-rail-row-height, 76px);
  align-items: flex-end;
}

/* Tech UI: hover enlarge like the card hover principle */
.page.tech .cert-rail-row .cert-rail__link {
  position: relative;
  align-items: flex-end;
}

