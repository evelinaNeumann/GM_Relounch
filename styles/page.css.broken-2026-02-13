  color: rgba(255, 255, 255, 0.7);
}

.modern-hero__title {
  font-size: clamp(2.2rem, 3vw + 1rem, 3rem);
  margin: 0;
}

.modern-hero__text {
  margin: 0;
  color: rgba(255, 255, 255, 0.9);
  font-size: 1rem;
}

.modern-hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.modern-hero__primary,
.modern-hero__secondary {
  border-radius: 0.65rem;
  padding: 0.65rem 1.5rem;
  font-size: 0.95rem;
  font-weight: 600;
  border: 1px solid transparent;
  cursor: pointer;
}

.modern-hero__primary {
  background: #ffffff;
  color: #008a92;
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
}

.modern-hero__secondary {
  background: transparent;
  border-color: rgba(255, 255, 255, 0.6);
  color: #ffffff;
}

.modern-breadcrumb {
  border-bottom: 1px solid rgba(15, 39, 66, 0.08);
  background: #f8fbfd;
}

.modern-breadcrumb__inner {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.6rem 0;
  font-size: 0.8rem;
  color: #5a6a7a;
}

.modern-breadcrumb__inner a {
  color: inherit;
  text-decoration: none;
}

.modern-main {
  padding: 2.5rem 0 3.5rem;
  background: linear-gradient(180deg, #f4f7fb 0%, #eaf1f7 100%);
}

.modern-main__grid {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.modern-services {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.modern-section-card {
  background: #ffffff;
  border-radius: 1rem;
  padding: 1.75rem;
  border: 1px solid rgba(15, 39, 66, 0.08);
  box-shadow: 0 20px 50px rgba(15, 39, 66, 0.08);
}

.modern-section-card__head {
  display: flex;
  flex-direction: column;
}

.modern-section-card__eyebrow {
  text-transform: uppercase;
  font-size: 0.75rem;
  letter-spacing: 0.14em;
  color: #5b6a7a;
  margin: 0 0 0.4rem;
}

.modern-section-card__title {
  margin: 0;
  font-size: 1.35rem;
}

.modern-section-card__divider {
  width: 80px;
  height: 3px;
  border-radius: 999px;
  background: #008a92;
  margin: 0.9rem 0 0.8rem;
}

.modern-section-card__text {
  margin: 0;
  color: #5b6a7a;
  font-size: 0.95rem;
}

.modern-service-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1rem;
}

.modern-service-grid .modern-service-card {
  background: #ffffff;
  border-radius: 0;
  padding: 1.5rem;
  border: 1px solid rgba(15, 39, 66, 0.08);
  display: flex;
  flex-direction: column;
  gap:  0.75rem;
  box-shadow: 0 18px 45px rgba(10, 29, 47, 0.07);
}

.modern-service-grid .modern-service-card__icon {
  width: 44px;
  height: 44px;
  border-radius: 0.85rem;
  background: rgba(0, 150, 153, 0.12);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
}

.modern-service-grid .modern-service-card__title {
  margin: 0;
  font-size: 1.2rem;
}

.modern-service-grid .modern-service-card__description {
  margin: 0;
  color: #5a6a7a;
  font-size: 0.9rem;
}

.modern-service-grid .modern-service-card__features {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  font-size: 0.85rem;
  color: #4b5c70;
}

.modern-service-grid .modern-service-card__features li {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.modern-service-grid .modern-service-card__bullet {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #008a92;
}

.card__icon {
  width: 2.1rem;
  height: 2.1rem;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(
    135deg,
    color-mix(in srgb, var(--color-accent) 45%, var(--color-accent-contrast, var(--color-accent)) 15%),
    var(--color-accent-soft)
  );
}

/* Tech UI card icon badge (square, tinted) */
.page.tech .card__icon {
  width: 3.2rem;
  height: 3.2rem;
  border-radius: 1rem;
  font-size: 1.45rem;
  background: var(--card-accent, rgb(12, 151, 155));
  color: #ffffff;
  box-shadow: 0 12px 26px color-mix(in srgb, var(--card-accent, rgb(12, 151, 155)) 28%, transparent);
}

.page.tech .card__icon svg {
  width: 1.7rem;
  height: 1.7rem;
  display: block;
}

.card__title {
  font-size: 1rem;
  position: relative;
  padding-left: 0.65rem;
}

.card__title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.25rem;
  bottom: 0.25rem;
  width: 0.18rem;
  border-radius: 999px;
  background: linear-gradient(180deg, var(--color-accent), var(--color-accent-contrast));
  opacity: 0.65;
}

/* Tech UI: bigger title, no left accent bar */
.page.tech .card__title {
  font-size: 1.45rem;
  font-weight: 750;
  letter-spacing: -0.01em;
  padding-left: 0;
  margin: 0.2rem 0 0;
}

.page.tech .card__title::before {
  display: none;
}

.card__text {
  font-size: 0.9rem;
  color: var(--color-muted);
}

.page.tech .card__text {
  font-size: 1rem;
  line-height: 1.45;
  margin: 0.25rem 0 0;
}

.card__text--spaced {
  margin-bottom: 0.75rem;
}

.card__bullets {
  padding-left: 1.1rem;
  margin: 0;
  list-style: disc;
  font-size: 0.85rem;
  color: var(--color-muted);
}

.page.tech .card__bullets {
  font-size: 0.95rem;
  padding-left: 1.1rem;
}

.page.tech .card__bullets li::marker {
  color: var(--card-accent, rgb(12, 151, 155));
}

.card__bullets li + li {
  margin-top: 0.2rem;
}

.card__cta {
  margin-top: 0.4rem;
  align-self: flex-start;
  border-radius: 999px;
  border: 3px solid color-mix(in srgb, var(--color-accent) 60%, transparent);
  padding: 0.45rem 0.9rem;
  font-size: 0.8rem;
  background: transparent;
  color: var(--color-text);
  cursor: pointer;
}

/* Tech UI: service cards keep pill button but follow per-card accent */
.page.tech .card--service .card__cta {
  border-width: 2px;
  border-color: color-mix(in srgb, var(--card-accent, rgb(12, 151, 155)) 55%, transparent);
  padding: 0.55rem 1.05rem;
  font-size: 0.88rem;
  font-weight: 650;
}

.page.tech .card--service .card__cta:hover {
  border-color: var(--card-accent, rgb(12, 151, 155));
  color: var(--card-accent, rgb(12, 151, 155));
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--card-accent, rgb(12, 151, 155)) 18%, transparent);
}

/* Tech UI: solution cards use link-style CTA like in the screenshot */
.page.tech .card--solution .card__cta {
  margin-top: auto;
  border: none;
  padding: 0;
  background: transparent;
  font-size: 1rem;
  font-weight: 650;
  color: var(--card-accent, rgb(12, 151, 155));
}

.page.tech .card--solution .card__cta::after {
  content: '›';
  margin-left: 0.45rem;
}

.page.tech .card--solution .card__cta:hover {
  text-decoration: underline;
  box-shadow: none;
}

.card--service .card__cta {
  margin-top: auto;
}

.card__cta:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent) 20%, transparent);
}

.card__meta {
  margin: 0;
  font-size: 0.8rem;
}

/* Tech UI: make service meta rows more readable */
.page.tech .cards--services .card__meta {
  font-size: 0.98rem;
  line-height: 1.35;
}

.page.tech .cards--services .card__meta-row {
  margin-top: 0.35rem;
}

.page.tech .cards--services .card__meta-row dt {
  font-weight: 700;
  color: rgba(15, 23, 42, 0.7);
}

.page.tech .cards--services .card__meta-row dd {
  font-weight: 600;
  color: rgba(15, 23, 42, 0.92);
}

.card__meta-row {
  display: flex;
  justify-content: space-between;
  gap: 0.75rem;
  margin-top: 0.15rem;
}

.card__meta-row dt {
  color: var(--color-muted);
}

.card__meta-row dd {
  margin: 0;
}

.card__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
}

.chip {
  font-size: 0.75rem;
  padding: 0.2rem 0.6rem;
  border-radius: 999px;
  background: var(--color-accent-soft);
}

/* Company layout */
.company-layout {
  display: grid;
  gap: 1.75rem;
  grid-template-columns: minmax(0, 3fr) minmax(0, 2.5fr);
}

.company-layout__headline {
  margin-bottom: 0.4rem;
  position: relative;
}

.company-layout__headline::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -0.3rem;
  width: 2.8rem;
  height: 2px;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--color-accent-contrast), var(--color-accent));
  opacity: 0.55;
}

.company-layout__text {
  font-size: 0.9rem;
  color: var(--color-muted);
  margin-bottom: 0.6rem;
}

.company-layout__list {
  padding-left: 1.15rem;
  font-size: 0.9rem;
  color: var(--color-muted);
}

.company-layout__list li + li {
  margin-top: 0.2rem;
}

.fact-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.85rem;
}

.fact-grid__item {
  padding: 0.85rem 0.7rem;
  border-radius: 0.9rem;
  background: var(--color-surface);
  border: 1px solid rgba(148, 163, 184, 0.3);
}

.page.tech .fact-grid__item {
  background: #ffffff;
  border-color: rgba(25, 35, 50, 0.08);
  box-shadow: 0 16px 36px rgba(25, 35, 50, 0.1);
}

.fact-grid__value {
  font-weight: 600;
  font-size: 1.1rem;
}

.fact-grid__label {
  font-size: 0.8rem;
  color: var(--color-muted);
}

/* Career */
.card__meta-inline {
  font-size: 0.8rem;
  color: var(--color-muted);
}

/* Contact */
.contact-layout {
  display: grid;
  gap: 1.6rem;
  grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
}

.page.business .business-contact .contact-layout,
.page.modern.business .business-contact .contact-layout {
  gap: 20px;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  padding: 1rem;
  box-sizing: border-box;
  border-radius: 1rem;
  background: var(--color-surface);
  border: 1px solid rgba(148, 163, 184, 0.3);
}

.page.business .business-contact .section__header {
  background: rgb(0, 150, 153);
  color: #ffffff;
  padding: 1.4rem 0;
}

.page.business .business-contact .section__title,
.page.business .business-contact .section__subtitle {
  color: #ffffff;
}

.page.business .business-contact .section__title {
  font-size: calc(1.4rem * 1.3);
  margin-left: 35px;
  display: inline-block;
}

.page.business .business-contact .section__title::after {
  background: var(--accent-red);
  opacity: 1;
  width: calc(100% + 2px);
}

.page.business .business-contact .section__subtitle {
  font-size: calc(0.9rem * 1.5);
  max-width: none;
  margin-left: 35px;
}

.page.business .business-contact .contact-form {
  background: #ffffff;
  border-color: rgb(0, 150, 153);
  align-self: stretch;
  min-width: 0;
  height: 100%;
  padding-bottom: 0.25rem;
}

.page.business .business-contact .contact-info {
  justify-self: end;
  align-self: stretch;
  width: min(100%, 26rem);
  min-width: 0;
  box-sizing: border-box;
  padding: 0.4rem 1.25rem;
  background: #ffffff;
  border: 1px solid rgb(0, 150, 153);
  border-radius: 1rem;
  font-size: calc(0.9rem * 2);
  color: var(--color-text);
  height: 100%;
}

.page.business .business-contact .contact-info__highlight {
  overflow-wrap: anywhere;
  word-break: break-word;
}

.page.business .business-contact .contact-info h3 {
  font-size: 1em;
  margin-bottom: 0.2rem;
}

.page.business .business-contact .contact-info__highlight {
  font-size: 1em;
  margin: 0.35rem 0 0.1rem;
}

.page.business .business-contact .contact-info__highlight {
  color: rgb(0, 150, 153);
}

/* Make both contact cards a bit taller, except for 800–1200px widths. */
@media (max-width: 799.98px), (min-width: 1200.02px) {
  .page.business .business-contact .contact-form,
  .page.modern.business .business-contact .contact-form {
    padding-bottom: 1rem;
  }

  .page.business .business-contact .contact-info,
  .page.modern.business .business-contact .contact-info {
    padding-top: 0.8rem;
    padding-bottom: 0.8rem;
  }
}

@media (min-width: 1600px) {
  .page.business .business-contact .contact-layout,
  .page.modern.business .business-contact .contact-layout {
    grid-template-columns: minmax(0, 1fr) minmax(0, calc(26rem - 20px));
  }

  .page.business .business-contact .contact-info,
  .page.modern.business .business-contact .contact-info {
    width: 100%;
    max-width: none;
    justify-self: stretch;
  }
}

.page.tech .contact-form {
  background: #ffffff;
  border: 1px solid rgba(25, 35, 50, 0.08);
}

.contact-form__row {
  display: grid;
  gap: 0.8rem;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.contact-form__field {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  font-size: 0.8rem;
}

.contact-form__field span {
  color: var(--color-muted);
}

.contact-form__field input,
.contact-form__field select,
.contact-form__field textarea {
  box-sizing: border-box;
  width: 100%;
  border-radius: 0.6rem;
  border: 1px solid rgba(148, 163, 184, 0.7);
  padding: 0.45rem 0.6rem;
  background: transparent;
  color: var(--color-text);
  font-size: 0.86rem;
}

.page.business .business-contact .contact-form__field input,
.page.business .business-contact .contact-form__field select,
.page.business .business-contact .contact-form__field textarea {
  border-color: rgb(0, 150, 153);
}

.page.tech .contact-form__field input,
.page.tech .contact-form__field select,
.page.tech .contact-form__field textarea {
  background: #ffffff;
  border-color: rgba(25, 35, 50, 0.12);
}

.contact-form__field input::placeholder,
.contact-form__field textarea::placeholder {
  color: rgba(148, 163, 184, 0.8);
}

.contact-form__field--full {
  grid-column: 1 / -1;
}

.contact-form__submit {
  margin-top: 0.4rem;
  align-self: flex-start;
}

.page.business .business-contact .contact-form__submit,
.page.modern.business .business-contact .contact-form__submit {
  width: 100%;
  align-self: stretch;
  justify-content: center;
}

.contact-info {
  font-size: 0.9rem;
  color: var(--color-muted);
}

.page.tech .contact-info {
  background: linear-gradient(135deg, rgba(0, 150, 153, 0.08), rgba(255, 255, 255, 0.95));
  padding: 1.25rem;
  border-radius: 1.2rem;
  border: 1px solid rgba(25, 35, 50, 0.08);
}

.contact-info h3 {
  color: var(--color-text);
  margin-bottom: 0.4rem;
}

.contact-info__highlight {
  font-size: 1rem;
  font-weight: 600;
  margin: 0.6rem 0 0.2rem;
  color: color-mix(in srgb, var(--color-accent) 85%, var(--color-text) 15%);
}

@media (min-width: 1024px) {
  .page.business .business-contact .contact-form {
    padding: calc(1rem * 1.15);
    padding-bottom: calc(0.25rem * 1.15);
    gap: calc(0.8rem * 1.15);
  }

  .page.business .business-contact .contact-form__row {
    gap: calc(0.8rem * 1.15);
  }

  .page.business .business-contact .contact-form__field {
    font-size: calc(0.8rem * 1.15);
  }

  .page.business .business-contact .contact-form__field input,
  .page.business .business-contact .contact-form__field select,
  .page.business .business-contact .contact-form__field textarea {
    font-size: calc(0.86rem * 1.15);
    padding: calc(0.45rem * 1.15) calc(0.6rem * 1.15);
  }

  .page.business .business-contact .contact-form__submit {
    font-size: calc(1rem * 1.15);
  }
}

/* Footer */
.footer {
  border-top: 1px solid rgba(148, 163, 184, 0.3);
  padding: 1.4rem 1.25rem 1.6rem;
  margin-top: 1.5rem;
  background: color-mix(in srgb, var(--color-bg) 90%, black 10%);
  position: relative;
  overflow: hidden;
}

.page.tech .footer:not(.footer--techgrid) {
  background: transparent;
  border-top: none;
  padding: 0;
}

.page.tech .footer:not(.footer--techgrid)::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  margin-left: -50vw;
  width: 100vw;
  background: rgb(231, 242, 242);
  border-top: 1px solid rgba(25, 35, 50, 0.08);
  box-shadow: 0 -16px 45px rgba(25, 35, 50, 0.15);
  z-index: 0;
}

.footer__inner {
  max-width: 1120px;
  margin: 0 auto;
  display: flex;
  gap: 1rem;
  align-items: center;
  justify-content: space-between;
  font-size: 0.9rem;
  color: var(--color-muted);
}

.footer__variant-toggle {
  margin-left: auto;
}

.footer__variant-toggle .variant-toggle {
  flex-wrap: wrap;
}

.page.tech .footer:not(.footer--techgrid) .footer__inner {
  max-width: 1280px;
  width: 100%;
  background: transparent;
  border-radius: 0;
  border: none;
  padding: 1.8rem 2rem;
  box-shadow: none;
  position: relative;
  z-index: 1;
}

/* Tech footer (image-inspired) */
.footer--techgrid {
  margin-top: 0;
  padding: 0;
  border-top: none;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.7);
  background: radial-gradient(circle at 15% 10%, rgba(0, 150, 153, 0.22), transparent 55%),
    radial-gradient(circle at 80% 0%, rgba(233, 40, 39, 0.22), transparent 55%),
    linear-gradient(180deg, rgb(8, 16, 30), rgb(10, 22, 39) 55%, rgb(8, 16, 30));
}

.footer--techgrid::before {
  content: none;
}

.footer__inner.footer__inner--techgrid {
  max-width: 1280px;
  margin: 0 auto;
  padding: clamp(2.6rem, 4vw, 3.6rem) clamp(1.25rem, 3vw, 2.75rem) 2.2rem;
  display: block;
  position: relative;
  font-size: 1.05rem;
  line-height: 1.55;
}

.footer__inner.footer__inner--tealgrid {
  max-width: 1280px;
  margin: 0 auto;
  padding: clamp(2.6rem, 4vw, 3.6rem) clamp(1.25rem, 3vw, 2.75rem) 2.2rem;
  display: block;
  position: relative;
  font-size: 1.05rem;
  line-height: 1.55;
}

/* Business/Modern footer (teal background, white text) */
.footer--tealgrid {
  margin-top: 0;
  padding: 0;
  border-top: none;
  overflow: hidden;
  color: rgba(255, 255, 255, 0.82);
  background: radial-gradient(circle at 15% 10%, rgba(255, 255, 255, 0.18), transparent 55%),
    radial-gradient(circle at 85% 0%, rgba(0, 0, 0, 0.16), transparent 60%),
    linear-gradient(140deg, rgb(0, 150, 153), rgb(0, 118, 122));
}

/* Managed Services: footer background should match main layout width (not full viewport width). */
.managed-services-page .footer--tealgrid {
  background: transparent;
}

.managed-services-page .footer__inner.footer__inner--tealgrid {
  width: 100%;
  max-width: 1678px;
  box-sizing: border-box;
  background: radial-gradient(circle at 15% 10%, rgba(255, 255, 255, 0.18), transparent 55%),
    radial-gradient(circle at 85% 0%, rgba(0, 0, 0, 0.16), transparent 60%),
    linear-gradient(140deg, rgb(0, 150, 153), rgb(0, 118, 122));
}

/* Business/Modern start page: constrain teal footer background to layout width (not full viewport). */
.page.business:not(.managed-services-page) .footer--tealgrid,
.page.modern:not(.managed-services-page) .footer--tealgrid {
  background: transparent;
}

.page.business:not(.managed-services-page) .footer__inner.footer__inner--tealgrid,
.page.modern:not(.managed-services-page) .footer__inner.footer__inner--tealgrid {
  width: 100%;
  max-width: 1680px;
  box-sizing: border-box;
  background: radial-gradient(circle at 15% 10%, rgba(255, 255, 255, 0.18), transparent 55%),
    radial-gradient(circle at 85% 0%, rgba(0, 0, 0, 0.16), transparent 60%),
    linear-gradient(140deg, rgb(0, 150, 153), rgb(0, 118, 122));
}

.footer--tealgrid::before {
  content: none;
}

.footer--tealgrid .logo--small {
  color: #ffffff;
}

.footer--tealgrid .footer__brand p {
  margin: 0.85rem 0 0;
  max-width: 26rem;
  color: rgba(255, 255, 255, 0.78);
  line-height: 1.55;
}

.footer--tealgrid .footer__col a {
  display: block;
  padding: 0.28rem 0;
  color: rgba(255, 255, 255, 0.78);
  text-decoration: none;
}

.footer--tealgrid .footer__col a:hover {
  color: #ffffff;
}

.footer--tealgrid .footer__divider {
  background: rgba(255, 255, 255, 0.22);
}

.footer--tealgrid .footer__bottom {
