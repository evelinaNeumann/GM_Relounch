  opacity: 0;
  transform: translateY(-28px) scale(0.97);
}

@keyframes cert-rail-pulse {
  0% {
    transform: scale(0.9);
    filter: saturate(0.92);
    opacity: 0.85;
  }
  25% {
    transform: scale(1.04);
    opacity: 0.95;
  }
  55% {
    transform: scale(1.15);
    filter: saturate(1.05);
    opacity: 1;
  }
  72% {
    transform: scale(1.08);
    opacity: 0.97;
  }
  100% {
    transform: scale(0.9);
    filter: saturate(0.9);
    opacity: 0.85;
  }
}

